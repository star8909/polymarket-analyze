# Polymarket 자동거래 환경변수 — 절대 commit 금지
# 사용: cp .env.example .env 후 값 채우기

# ─── 인증 ───
PRIVATE_KEY=0x_여기에_private_key_64자
FUNDER_ADDRESS=0x_proxy_or_EOA_주소
SIGNATURE_TYPE=1
# 1=Magic email wallet, 0=MetaMask EOA, 2=browser wallet proxy

# ─── 엔드포인트 ───
CLOB_HOST=https://clob.polymarket.com
CHAIN_ID=137

# ─── 안전장치 ───
MAX_BET_USD=20
DAILY_LOSS_LIMIT_USD=100
EDGE_THRESHOLD_PP=5
KELLY_FRACTION=0.25
KILL_SWITCH_FILE=KILL
MIN_VOLUME_24H_USD=5000
MIN_DAYS_TO_SETTLE=7
